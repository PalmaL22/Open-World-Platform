generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  username  String?
  lastX     Float?   @default(0)
  lastY     Float?   @default(0)
  createdAt DateTime @default(now())
}
