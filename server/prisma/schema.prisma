generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Server {
  id          String @id @default(cuid())
  name        String @unique
  maxCapacity Int    @default(32)
  users       User[]
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  password        String
  username        String     @unique
  currentServerId String?
  character       Character?
  currentServer   Server?    @relation(fields: [currentServerId], references: [id])
}

model Character {
  id       String  @id @default(cuid())
  userId   String  @unique
  color    String  @default("#3498db")
  hat      String?
  facewear String?
  user     User    @relation(fields: [userId], references: [id])
}
